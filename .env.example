# Copy this file to .env.local for local development (vercel dev)
# In production, set these in the Vercel dashboard under Settings → Environment Variables

# Asana Personal Access Token — generated from a bot/service Asana account
# with read access to the L10: RevOps project.
# Create one at: https://app.asana.com/0/my-apps
ASANA_PAT=

# The GID of the L10: RevOps project. Already hardcoded as the default, but
# override here if you clone this project to a different board.
ASANA_PROJECT_GID=1213046253934403
